# =============================================================================
#  Helix Thready — shared example environment
#  Location : docs/public/research/mvp/api/materials/examples/env.example
#  Usage    : cp env.example .env && edit values && `source .env`
#             (the curl *.curl.sh and httpie *.http collections read these vars)
#  Provenance: [DEFAULT — adjustable] values derived from openapi.yaml `servers`
#             and the auth/idempotency/HMAC schemes it declares.
# =============================================================================

# --- Endpoint ---------------------------------------------------------------
# One of the three declared servers (openapi.yaml `servers`):
#   Production : https://thready.hxd3v.com/v1
#   Staging    : https://sta.thready.hxd3v.com/v1
#   Development: https://dev.thready.hxd3v.com/v1
export THREADY_BASE="${THREADY_BASE:-https://dev.thready.hxd3v.com/v1}"

# --- Credentials ------------------------------------------------------------
# A JWT access token (from POST /auth/login) OR a scoped API key ("sk-...").
# Both are presented as `Authorization: Bearer <value>` (bearerAuth / apiKeyAuth).
export THREADY_TOKEN="${THREADY_TOKEN:-eyJhbGciOiJSUzI1Ni4REPLACE_ME}"
export THREADY_REFRESH="${THREADY_REFRESH:-eyJhbGciOiJSUzI1Ni4REPLACE_ME_REFRESH}"

# Login credentials for the auth collection (admin tiers require TOTP).
export THREADY_EMAIL="${THREADY_EMAIL:-user@t1.example}"
export THREADY_PASSWORD="${THREADY_PASSWORD:-correct-horse-battery}"
export THREADY_TOTP="${THREADY_TOTP:-123456}"

# --- Resource ids (fill after you create/list the resources) ----------------
export THREADY_ACCOUNT_ID="${THREADY_ACCOUNT_ID:-a1c2e3d4-0000-4000-8000-000000000001}"
export THREADY_USER_ID="${THREADY_USER_ID:-b2d3f4a5-0000-4000-8000-000000000002}"
export THREADY_CHANNEL_ID="${THREADY_CHANNEL_ID:-3a2b1c00-0000-4000-8000-000000000009}"
export THREADY_POST_ID="${THREADY_POST_ID:-9b1e4c00-0000-4000-8000-000000000001}"
export THREADY_ASSET_ID="${THREADY_ASSET_ID:-5f2a6b7c-0000-4000-8000-000000000003}"
export THREADY_SKILL_ID="${THREADY_SKILL_ID:-video.download}"
export THREADY_KEY_ID="${THREADY_KEY_ID:-7c9a8b6d-0000-4000-8000-000000000004}"
export THREADY_SINK_ID="${THREADY_SINK_ID:-6e5d4c3b-0000-4000-8000-000000000005}"

# --- Idempotency (unsafe async POSTs) ---------------------------------------
# A client-supplied UUID; a same-key+same-body replay returns the original result,
# a same-key+different-body request returns 409 conflict (openapi.yaml IdempotencyKey).
export THREADY_IDEMPOTENCY_KEY="${THREADY_IDEMPOTENCY_KEY:-$(cat /proc/sys/kernel/random/uuid 2>/dev/null || echo 11111111-2222-4333-8444-555555555555)}"

# --- Inbound 3rd-party callbacks (HMAC, NOT a JWT) --------------------------
# Per-provider shared secret provisioned out of band; used to sign the raw body
# into the `X-Thready-Signature` header (hmacAuth scheme). See processing.curl.sh.
export THREADY_HMAC_SECRET="${THREADY_HMAC_SECRET:-provisioned-per-provider-secret}"
