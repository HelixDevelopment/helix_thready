# =============================================================================
# Helix Thready — deployment-scoped environment (EXAMPLE, safe to commit)
# Copy to        : /home/thready/<env>/.env   then `chmod 600`   (gitignored on the host)
# Source         : materialized from environments.md §7 + secrets-and-config.md §4/§8 + service-discovery-ports.md §4.
# Scope          : ONLY deployment/orchestration variables + the NAMES of injected secrets.
#                  Real secret VALUES live exclusively in the private repo (helix_thready_private) and are
#                  copied onto the host as chmod-600 files — NEVER committed to a public repo [CONSTITUTION §11.4.10].
# Example values : shown for PROD (band 62). For sta use prefix 61, for dev use prefix 60 (and LE_STAGING=1 first).
# =============================================================================

# ----------------------------------------------------------------- environment selector
THREADY_ENV=prod                       # dev | sta | prod — selects config, port band, project name
THREADY_PORT_PREFIX=62                  # port_prefix band: dev=60, sta=61, prod=62 [DEFAULT — adjustable]
THREADY_PUBLIC_HOST=thready.hxd3v.com   # canonical URL, CORS, cookie domain (dev.=/sta.=subdomains)
THREADY_LOG_LEVEL=info                  # dev=debug, sta=info, prod=info

# ----------------------------------------------------------------- release / image versions (tag pinning)
THREADY_VERSION=THREADY-1.4.0           # localhost/thready-<component>:${THREADY_VERSION} (digest-pinned in the manifest)
BOBA_VERSION=latest                     # localhost/boba:${BOBA_VERSION}   (pin before prod)
METUBE_VERSION=latest                   # localhost/metube:${METUBE_VERSION}

# ----------------------------------------------------------------- DYNAMIC host ports (port_prefix defaults)
# These are consumed by the compose files as ${PP_<internal>:-<default>}. Regenerate deterministically with:
#   eval "$(port_prefix --prefix ${THREADY_PORT_PREFIX} \
#           --ports 5432,6379,4222,8222,9000,9001,8123,9009,8443,8088,7080,8081,8082,8083,8084,8085,8000,8091,9090,3000,16686,4317 \
#           --export)"
# The values below are the VERIFIED prod (62) mapping incl. the three collision probes (service-discovery-ports.md §4).
PP_5432=62432    # postgres
PP_6379=62379    # redis
PP_4222=62222    # nats client
PP_8222=62223    # nats monitoring (8222 mod 1000 collides with 4222 → probe → ...223)
PP_9000=62000    # minio S3
PP_9001=62001    # minio console
PP_8123=62123    # clickhouse HTTP
PP_9009=62009    # clickhouse native
PP_8443=62443    # thready-api (the edge reverse-proxies here)
PP_8088=62088    # thready-web
PP_7080=62080    # thready-herald
PP_8081=62081    # thready-assetsvc   (buildnew)
PP_8082=62082    # thready-downloadmgr (buildnew)
PP_8083=62083    # thready-usersvc    (buildnew)
PP_8084=62084    # thready-eventbus-svc (buildnew)
PP_8085=62085    # thready-semsearch  (buildnew)
PP_8000=62002    # boba (8000 → 000/001 taken by minio → probe → ...002)
PP_8091=62091    # metube
PP_9090=62090    # prometheus
PP_3000=62003    # grafana (3000 → 000/001/002 taken → probe → ...003)
PP_16686=62686   # jaeger UI
PP_4317=62317    # jaeger OTLP gRPC

# ----------------------------------------------------------------- HelixLLM external endpoint (Q5, GAP #1 / #17)
HELIX_EMBEDDING_PROVIDER=llama                       # GAP #1 — MUST be 'llama'; deploy pre-flight + semsearch probe assert this
HELIX_LLM_BASE_URL=http://gpu-node.helix.lan:8080    # OpenAI-compatible base (/v1/chat, /v1/embeddings) — Required
HELIX_LLM_VERIFIER_URL=http://gpu-node.helix.lan:8080 # GAP #17 — pin explicitly; HelixLLM's :7061 default is wrong (LLMsVerifier serves :8080)

# ----------------------------------------------------------------- processing knobs
THREADY_BG_WORKERS=32                   # BackgroundTasks workers: dev=8, sta=16, prod=32 (Q4)

# ----------------------------------------------------------------- edge / TLS deploy gate (used by deploy.sh)
# The FULL lets_encrypt config (LE_DOMAINS, LE_CERT_DIR, LE_CHALLENGE, ...) lives in
# /home/thready/<env>/config/lets_encrypt.conf (chmod 600). Only the deploy-time knobs are here:
LE_VALIDATE_URL=https://thready.hxd3v.com/health/ready   # end-to-end edge probe (deploy.sh promotion gate)
LE_STAGING=0                            # dev rehearses with 1 first, then flips to 0; sta/prod = 0

# ----------------------------------------------------------------- INJECTED SECRETS (names only — values from private repo)
# The deploy pre-flight fails fast (mustEnv) if any of these is unset. Replace __from_private_repo__ on the host.
THREADY_PG_USER=thready_prod
THREADY_PG_PASSWORD=__from_private_repo__
THREADY_PG_DSN=postgres://thready_prod:__from_private_repo__@thready-postgres:5432/thready
THREADY_NATS_URL=nats://thready-nats:4222
THREADY_MINIO_ENDPOINT=http://thready-minio:9000
THREADY_MINIO_ROOT_USER=__from_private_repo__
THREADY_MINIO_ROOT_PASSWORD=__from_private_repo__
THREADY_GRAFANA_ADMIN_USER=admin
THREADY_GRAFANA_ADMIN_PASSWORD=__from_private_repo__
# NOTE: LLM/messenger/DNS-01 API keys (HELIX_LLM_API_KEY, HERALD_TELEGRAM_*, LOOPIA_*) are sourced
#       separately from /home/thready/secrets/api_keys.sh (chmod 600) — see secrets-and-config.md §2.
