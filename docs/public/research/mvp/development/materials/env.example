# =============================================================================
#  Helix Thready — .env.example  (COMPLETE master template)
#  Classification : PUBLIC
#  Location       : docs/public/research/mvp/development/materials/env.example
#  Status         : Draft — v0.1 (zero-version scaffold; illustrative, NOT a shipped file)
#  Revision       : 1 (2026-07-22) — swarm (development/materials)
#  Source of truth: ../../user-guides/configuration.md  (§4–§16 + Appendix A/B)
#  Conventions    : ../../CONVENTIONS.md
#
#  HOW TO USE
#    cp env.example .env  &&  chmod 600 .env      # never commit .env  [CONSTITUTION §11.4.10]
#    Fill only the variables your role/environment needs. Missing OPTIONAL sources are
#    SKIPPED silently; missing REQUIRED vars make the service FAIL LOUDLY at boot listing
#    the missing keys (configuration.md §1). Secrets (*_PASSWORD/*_TOKEN/*_API_KEY/*_SECRET/
#    *_KEY/DSNs) are redacted in every log sink — never printed.
#
#  PROVENANCE MARKERS (inline, per configuration.md):
#    (V)  VERIFIED  — a real in-house module variable read at source (must NOT be renamed)
#    (A)  ASSUMPTION — a THREADY_* name proposed by configuration.md (ratify vs config struct)
#    (D)  [DEFAULT — adjustable] proposed enterprise default
#    (op) [OPERATOR] operator decision   (R) [RESEARCH]   (gap) tied to a gap-register item
#    (BN) [BUILD-NEW] — service not shipped yet; variable reserved for when it lands
#
#  ANTI-BLUFF NOTE. Rows marked (BN)/(gap) reference subsystems that are stubs, scaffolds or
#  unbuilt (see configuration.md and the private gap register). Setting such a variable does
#  NOT make the feature work — it only configures the seam for when the module lands.
#
#  1:1 CROSS-CHECK vs configuration.md — see the CROSS-CHECK REPORT block at the END of file.
# =============================================================================


# =============================================================================
# 1. CORE RUNTIME & SERVER                                (configuration.md §4)
# =============================================================================

# Select env profile & safety rails; drives log format + safety defaults.
# Default: development. Scope: all services. (A)
THREADY_ENV=development

# Explicit .env path (overrides CWD lookup).
# Default: ./.env. Scope: all services. (A)
THREADY_ENV_FILE=./.env

# REST /v1 + WS/SSE bind address.
# Default: 0.0.0.0:8443. Scope: API server. (A)
THREADY_HTTP_ADDR=0.0.0.0:8443

# Enable HTTP/3 (QUIC) via vasic-digital/http3; falls back to HTTP/2.
# Default: true. Scope: API server. (V) [IN-HOUSE: http3]
THREADY_HTTP3_ENABLED=true

# Response compression (Brotli/gzip).
# Default: br,gzip. Scope: API server. (D)
THREADY_HTTP_COMPRESSION=br,gzip

# logrus level: debug|info|warn|error.
# Default: info. Scope: all services. (V) [IN-HOUSE: observability]
THREADY_LOG_LEVEL=info

# Log format: json|text (text in dev).
# Default: json. Scope: all services. (V) [IN-HOUSE: observability]
THREADY_LOG_FORMAT=json

# Per-request server timeout.
# Default: 30s. Scope: API server. (D)
THREADY_REQUEST_TIMEOUT=30s

# Per-identity request rate cap.
# Default: 100. Scope: API server. (V) [IN-HOUSE: ratelimiter]
THREADY_RATE_LIMIT_RPS=100

# Allowed browser origins (portal domains), CSV. Empty = none allowed.
# Default: (none). Scope: API server. (V) [IN-HOUSE: middleware]
THREADY_CORS_ORIGINS=

# Deterministic dynamic-port base for the container stack (<=65535 budget).
# Default: unset. Scope: container stack. (V) [IN-HOUSE: port_prefix]
# THREADY_PORT_PREFIX=24


# =============================================================================
# 2. ENVIRONMENTS, DOMAINS & TLS                          (configuration.md §5)
# =============================================================================

# Base domain. dev/staging derive dev./sta. prefixes.
# Default: thready.hxd3v.com. Scope: all services. (op) [OPERATOR]
THREADY_PUBLIC_DOMAIN=thready.hxd3v.com

# Absolute base for links in generated content & emails.
# Default: https://thready.hxd3v.com. Scope: API/content. (A)
THREADY_PUBLIC_BASE_URL=https://thready.hxd3v.com

# ACME account email (acme.sh / Let's Encrypt).
# Default: unset. Scope: proxy/prod. (V) [IN-HOUSE: lets_encrypt]
LETS_ENCRYPT_EMAIL=

# ACME challenge type: http-01|dns-01.
# Default: http-01. Scope: proxy/prod. (V) [IN-HOUSE: lets_encrypt]
LETS_ENCRYPT_CHALLENGE=http-01

# Minimum TLS version.
# Default: 1.3. Scope: API/proxy. (D)
THREADY_TLS_MIN_VERSION=1.3


# =============================================================================
# 3. DEPLOYMENT — remote container distribution           (configuration.md §5)
#    All CONTAINERS_REMOTE_* names VERIFIED in helix_track/containers/.env.example.
# =============================================================================

# Enable remote container distribution.
# Default: false. Scope: deploy. (V) [IN-HOUSE: containers]
CONTAINERS_REMOTE_ENABLED=false

# SSH user for deploy targets (Thready uses `thready`).
# Default: deploy. Scope: deploy. (V)
CONTAINERS_REMOTE_DEFAULT_SSH_USER=deploy

# Container runtime: docker|podman. Thready = rootless Podman only [CONSTITUTION §11.4.76].
# Default: podman. Scope: deploy. (V)
CONTAINERS_REMOTE_DEFAULT_RUNTIME=podman

# Private key for deploy-target SSH (else the agent).
# Default: unset. Scope: deploy. (V)
# CONTAINERS_REMOTE_DEFAULT_SSH_KEY=~/.ssh/thready_deploy

# Tunnel/port range for remote deploys.
# Default: 20000 / 30000. Scope: deploy. (V)
CONTAINERS_REMOTE_PORT_RANGE_START=20000
CONTAINERS_REMOTE_PORT_RANGE_END=30000

# SSH connect timeout to a deploy target.
# Default: 10s. Scope: deploy. (V)
CONTAINERS_REMOTE_CONNECT_TIMEOUT=10s

# Per-remote-command timeout.
# Default: 5m. Scope: deploy. (V)
CONTAINERS_REMOTE_COMMAND_TIMEOUT=5m

# Re-use one SSH control connection (ControlMaster).
# Default: true. Scope: deploy. (V)
CONTAINERS_REMOTE_SSH_CONTROL_MASTER=true

# How long the multiplexed SSH master lingers.
# Default: 60s. Scope: deploy. (V)
CONTAINERS_REMOTE_SSH_CONTROL_PERSIST=60s

# Concurrent SSH connections per target.
# Default: 10. Scope: deploy. (V)
CONTAINERS_REMOTE_SSH_MAX_CONNECTIONS=10

# Placement across multiple remote hosts: roundrobin|leastloaded.
# Default: roundrobin. Scope: deploy. (V)
CONTAINERS_REMOTE_SCHEDULER=roundrobin

# Default mount type for remote deploys: bind|volume.
# Default: volume. Scope: deploy. (V)
CONTAINERS_REMOTE_VOLUME_TYPE=volume


# =============================================================================
# 4. RELATIONAL DATABASE                                  (configuration.md §6)
#    digital.vasic.database — SQLite (cgo-free) dev / PostgreSQL (pgx/v5) prod.
# =============================================================================

# Relational backend: sqlite|postgres.
# Default: sqlite (dev) / postgres (prod). Scope: all services. (V) [IN-HOUSE: database]
THREADY_DB_DRIVER=sqlite

# DB connection string. SQLite: file:...  Postgres: postgres://user:pass@host:5432/db
# Default: see below. Scope: all services. (V)
THREADY_DB_DSN=file:./data/thready.db?_pragma=busy_timeout(5000)

# pgx pool size (tune for Large scale).
# Default: 32. Scope: all services. (D)
THREADY_DB_MAX_OPEN_CONNS=32

# Idle pool size.
# Default: 8. Scope: all services. (D)
THREADY_DB_MAX_IDLE_CONNS=8

# Connection recycle lifetime.
# Default: 30m. Scope: all services. (D)
THREADY_DB_CONN_MAX_LIFETIME=30m

# Auto-run migration.Runner.Apply at start (prod runs migrations via deploy step).
# Default: true (dev) / false (prod). Scope: API/migrator. (V)
THREADY_DB_MIGRATE_ON_BOOT=true

# Time-partitioned `posts` for 10k+/day. Partitioning helpers are a P1 improvement — best-effort.
# Default: true (prod). Scope: DB. (gap) [GAP: 3.2]
# THREADY_DB_PARTITIONING=true


# =============================================================================
# 5. VECTOR DB / SEMANTIC SEARCH                          (configuration.md §7.1)
#    digital.vasic.vectordb — only pgvector is VERIFIED/production-wired [GAP: 8].
# =============================================================================

# Vector store: pgvector|qdrant|pinecone|milvus. Only pgvector VERIFIED; others [OPEN].
# Default: pgvector. Scope: search/workers. (V) [IN-HOUSE: vectordb]
THREADY_VECTOR_BACKEND=pgvector

# Vector DB DSN. pgvector co-locates in the relational Postgres.
# Default: shares Postgres. Scope: search/workers. (V)
THREADY_VECTOR_DSN=postgres://thready:thready@localhost:5432/thready?sslmode=disable

# Distance metric: cosine|l2|ip.
# Default: cosine. Scope: search. (V)
THREADY_VECTOR_METRIC=cosine

# Embedding dimension — MUST match the embedding model's true dimension.
# RAG path historically hardcoded 768 — set this explicitly. Default: 1024. Scope: search/workers. (gap) [GAP: 1]
THREADY_EMBEDDING_DIM=1024

# ANN index for the <500ms search SLO: hnsw|ivfflat.
# Default: hnsw. Scope: search. (D)
THREADY_VECTOR_INDEX=hnsw

# Qdrant endpoint (only if backend=qdrant; hardening tracked as [OPEN], unverified).
# Default: unset. Scope: search. (gap) [GAP: 8]
# THREADY_QDRANT_URL=http://qdrant:6333


# =============================================================================
# 6. CACHE                                                (configuration.md §7.2)
# =============================================================================

# Cache tier: memory|redis|postgres (L1/L2 supported).
# Default: memory (dev) / redis (prod). Scope: all services. (V) [IN-HOUSE: cache]
THREADY_CACHE_BACKEND=memory

# Redis URL (redis://host:6379/0).
# Default: unset. Scope: all services. (V)
# THREADY_CACHE_REDIS_URL=redis://cache:6379/0

# Default cache entry TTL.
# Default: 10m. Scope: all services. (D)
THREADY_CACHE_TTL=10m


# =============================================================================
# 7. OBJECT STORAGE (ASSETS)                              (configuration.md §7.3)
#    digital.vasic.storage (MinIO/S3) — the asset tier for 50 TB+ scale.
# =============================================================================

# Asset store backend: filesystem|minio|s3.
# Default: filesystem (dev) / minio (prod). Scope: asset service. (V) [IN-HOUSE: storage]
THREADY_STORAGE_BACKEND=filesystem

# MinIO/S3 endpoint.
# Default: unset. Scope: asset service. (V)
# THREADY_STORAGE_ENDPOINT=https://minio:9000

# Object bucket.
# Default: thready-assets. Scope: asset service. (A)
THREADY_STORAGE_BUCKET=thready-assets

# Storage access key (SECRET — redacted in logs).
# Default: unset. Scope: asset service. (V)
THREADY_STORAGE_ACCESS_KEY=

# Storage secret key (SECRET — redacted in logs).
# Default: unset. Scope: asset service. (V)
THREADY_STORAGE_SECRET_KEY=

# Signed-URL lifetime. MinIO signed-URL parity with CloudFront is a P1 verification item.
# Default: 15m. Scope: asset service. (gap) [GAP: 3.2]
THREADY_STORAGE_SIGNED_URL_TTL=15m


# =============================================================================
# 8. EMBEDDINGS  (P0 TRAP — READ THIS)                    (configuration.md §8.1)
#    HelixLLM's DEFAULT local embedder is a non-semantic HashEmbedder stub that
#    returns garbage relevance. You MUST use a real provider for any search/RAG.
# =============================================================================

# Embedder provider: llama|openai|hash.  `hash` is BLOCKED for search — selecting it
# in a search/RAG context ABORTS start-up (fail-loud, not warn).
# Default: llama (ENFORCED). Scope: search/workers. (V) [IN-HOUSE: HelixLLM] [GAP: 1]
HELIX_EMBEDDING_PROVIDER=llama

# OpenAI-compatible embeddings endpoint (HelixLLM /v1/embeddings).
# Default: http://localhost:8080/v1. Scope: search/workers. (V)
THREADY_EMBEDDING_BASE_URL=http://localhost:8080/v1

# Embedding model (code-tuned; alt voyage-code-3).
# Default: jina-embeddings-v2-base-code. Scope: search/workers. (R) [RESEARCH]
THREADY_EMBEDDING_MODEL=jina-embeddings-v2-base-code

# Embedding endpoint API key (SECRET — only if the endpoint requires it).
# Default: unset. Scope: search/workers. (V)
THREADY_EMBEDDING_API_KEY=


# =============================================================================
# 9. LLM PROVIDERS (HelixLLM + LLMProvider)               (configuration.md §8.2)
#    Bare provider-key names VERIFIED from llm_provider/.env.example — do NOT rename.
#    Set only the ones you use; missing keys are skipped.
# =============================================================================

# Local llama.cpp server URL (OpenAI + Anthropic APIs).
# Default: unset. Scope: workers. (V) [IN-HOUSE: HelixLLM]
# HELIX_LLM_BASE_URL=http://llm:8080

# Reasoning/research model, e.g. Llama-3.1-70B-Instruct-Q4_K_M.
# Default: unset. Scope: workers. (V)
# HELIX_LLM_MODEL=Llama-3.1-70B-Instruct-Q4_K_M

# Code model, e.g. Qwen2.5-Coder.
# Default: unset. Scope: workers. (V)
# HELIX_LLM_CODE_MODEL=Qwen2.5-Coder

# Cloud LLM fallback keys (SECRET). Set as needed.
# Default: unset. Scope: workers. (V)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Additional LLMProvider adapters (SECRET). Set as needed.
# Default: unset. Scope: workers. (V)
GROQ_API_KEY=
MISTRAL_API_KEY=
QWEN_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
NVIDIA_API_KEY=

# Further VERIFIED LLMProvider adapters (SECRET).
# Default: unset. Scope: workers. (V)
CEREBRAS_API_KEY=
FIREWORKS_API_KEY=
HUGGINGFACE_API_KEY=
SAMBANOVA_API_KEY=
SILICONFLOW_API_KEY=

# Replicate uses a *_TOKEN (not *_API_KEY) spelling — do NOT rename.
# Default: unset. Scope: workers. (V)
REPLICATE_API_TOKEN=

# Provider retry ceiling.
# Default: 5. Scope: workers. (D)
THREADY_LLM_MAX_RETRIES=5

# Circuit breaker for flapping providers.
# Default: true. Scope: workers. (V) [IN-HOUSE: LLMProvider]
THREADY_LLM_CIRCUIT_BREAKER=true

# --- FLAGGED: present in the private gap register (§2.1.3) but NOT in configuration.md ---
# HelixLLM defaults HELIX_LLM_VERIFIER_URL=:7061 while LLMsVerifier serves :8080 (port
# discrepancy, P2, unresolved). Left commented + flagged here; see CROSS-CHECK REPORT below.
# Default: :7061 (HelixLLM internal). Scope: workers. (V, gap) [GAP: 17]
# HELIX_LLM_VERIFIER_URL=:7061


# =============================================================================
# 10. VISION & OCR (VisionEngine)                         (configuration.md §8.3)
#     HELIX_VISION_* VERIFIED in vision_engine/.env.example. NO OCR ENGINE yet (P0
#     gap) — OpenCV de-duplicates frames, it does NOT transcribe text [GAP: 2].
# =============================================================================

# Vision provider: auto|openai|anthropic|gemini|qwen|astica|nvidia|kimi|stepfun|ollama.
# Default: auto. Scope: vision workers. (V) [IN-HOUSE: VisionEngine]
HELIX_VISION_PROVIDER=auto

# Vision call timeout (seconds).
# Default: 60. Scope: vision workers. (V)
HELIX_VISION_TIMEOUT=60

# Downscale ceiling (px).
# Default: 4096. Scope: vision workers. (V)
HELIX_VISION_MAX_IMAGE_SIZE=4096

# Enable the OpenCV pre-analysis pass (SSIM/near-duplicate detection) — NOT OCR.
# Default: true. Scope: vision workers. (V)
HELIX_VISION_OPENCV_ENABLED=true

# Structural-similarity cutoff for treating two frames/images as duplicates (0..1).
# Default: 0.95. Scope: vision workers. (V)
HELIX_VISION_SSIM_THRESHOLD=0.95

# Vision worker hosts to distribute calls across (CSV, e.g. thinker.local,amber.local).
# Default: unset. Scope: vision workers. (V)
# HELIX_VISION_HOSTS=thinker.local,amber.local

# SSH user for the remote vision hosts.
# Default: unset. Scope: vision workers. (V)
# HELIX_VISION_USER=helix

# Local Ollama endpoint (when HELIX_VISION_PROVIDER=ollama).
# Default: http://localhost:11434. Scope: vision workers. (V)
HELIX_OLLAMA_URL=http://localhost:11434

# Local multimodal model for Ollama vision.
# Default: minicpm-v:8b. Scope: vision workers. (V)
HELIX_OLLAMA_MODEL=minicpm-v:8b

# Use a llama.cpp RPC worker pool for local vision.
# Default: false. Scope: vision workers. (V)
HELIX_LLAMACPP_RPC_ENABLED=false

# RPC worker addresses (CSV host:port; only if RPC enabled).
# Default: unset. Scope: vision workers. (V)
# HELIX_LLAMACPP_RPC_WORKERS=

# GGUF model for the RPC vision path.
# Default: ~/models/vision-model.gguf. Scope: vision workers. (V)
HELIX_LLAMACPP_RPC_MODEL=~/models/vision-model.gguf

# Vision-provider API keys (SECRET) for astica / kimi / stepfun.
# Default: unset. Scope: vision workers. (V)
ASTICA_API_KEY=
KIMI_API_KEY=
STEPFUN_API_KEY=

# OCR engine: tesseract|paddleocr|none. Real OCR pending the adapter; none = LLM-vision only.
# Default: none. Scope: vision workers. (BN) [BUILD-NEW] [GAP: 2]
THREADY_OCR_PROVIDER=none

# Tesseract language packs (CSV). Add `srp` for Serbian-Cyrillic content (§15 locale sr-Cyrl).
# Default: eng,rus. Scope: vision workers. (D)
THREADY_OCR_LANGS=eng,rus


# =============================================================================
# 11. MESSENGERS (Herald)                                 (configuration.md §9)
#     VERIFIED names read from vasic-digital/herald/.env.example. Two Telegram
#     transports: MTProto user client READS history; Bot API REPLIES only.
#     Max = empty stub (adapter PLANNED, not built) [GAP: 3].
# =============================================================================

# --- Telegram MTProto user client (READS full thread history / backfill) ---

# app_id from my.telegram.org/apps (~5-8 digits). SECRET.
# Default: unset. Scope: ingest. (V) [IN-HOUSE: herald]
HERALD_MTPROTO_APP_ID=

# Paired app_hash from my.telegram.org/apps (32-hex). SECRET.
# Default: unset. Scope: ingest. (V)
HERALD_MTPROTO_APP_HASH=

# Phone (E.164) of the reading USER account; first run triggers an SMS/app login code.
# Default: unset. Scope: ingest. (V)
HERALD_MTPROTO_PHONE=

# Cloud 2FA password (SECRET); only prompted if Telegram returns SESSION_PASSWORD_NEEDED.
# Default: unset. Scope: ingest. (V)
HERALD_MTPROTO_PASSWORD=

# Persisted MTProto session (avoids re-login). Store on an encrypted path.
# Default: ~/.config/herald/mtproto.session. Scope: ingest. (V)
HERALD_MTPROTO_SESSION_FILE=~/.config/herald/mtproto.session

# --- Telegram Bot API (status replies / notify — CANNOT backfill history) ---

# @BotFather token (NNNNNNNNNN:35-char). SECRET.
# Default: unset. Scope: reply. (V)
HERALD_TGRAM_BOT_TOKEN=

# Target chat: private DM positive, group negative, supergroup -100<id>.
# Default: unset. Scope: reply. (V)
HERALD_TGRAM_CHAT_ID=

# Enable the Bot-API inbound long-poll listener.
# Default: false. Scope: reply. (V)
HERALD_TGRAM_LIVE_INBOUND=false

# Telegram user IDs allowed to issue operator commands (CSV int).
# Default: unset. Scope: reply. (V)
# HERALD_OPERATOR_IDS=111,222

# --- Max (RESERVED — adapter PLANNED, not implemented; no code consumes these yet) ---

# Max Bot-API token (SECRET). Reserved. Default: unset. Scope: (none yet). (V, reserved)
HERALD_MAX_BOT_TOKEN=
# Max chat id. Reserved. Default: unset. Scope: (none yet). (V, reserved)
HERALD_MAX_CHAT_ID=

# --- Thready messenger orchestration ---

# Sign-in mode: interactive|noninteractive (noninteractive reads all creds from env for headless deploy).
# Default: interactive. Scope: ingest. (op) [OPERATOR]
THREADY_MESSENGER_SIGNIN_MODE=interactive

# Scheduled wake frequency; event triggers supplement polling.
# Default: 5m. Scope: ingest. (D)
THREADY_POLL_INTERVAL=5m

# Which account posts status replies: robot (Bot API) | user (MTProto).
# Default: robot. Scope: reply. (D)
THREADY_REPLY_ACCOUNT=robot


# =============================================================================
# 12. EVENT BUS, BACKGROUND JOBS & PROCESSING            (configuration.md §10)
#     digital.vasic.eventbus — in-process bus + NATS JetStream durable adapter.
# =============================================================================

# Event transport: inprocess|nats. NATS JetStream is the Large-scale transport.
# Default: inprocess (dev) / nats (prod). Scope: all services. (V) [IN-HOUSE: eventbus]
THREADY_EVENTBUS_BACKEND=inprocess

# NATS URL (nats://host:4222).
# Default: unset. Scope: all services. (V)
# THREADY_NATS_URL=nats://nats:4222

# JetStream stream name.
# Default: thready. Scope: all services. (A)
THREADY_NATS_STREAM=thready

# BackgroundTasks worker-pool size (Q4).
# Default: 32. Scope: workers. (D)
THREADY_WORKERS=32

# Max retries per step/post (§3.3).
# Default: 5. Scope: workers. (D)
THREADY_RETRY_MAX=5

# Exponential back-off base.
# Default: 2s. Scope: workers. (D)
THREADY_RETRY_BASE=2s

# Back-off multiplier.
# Default: 2.0. Scope: workers. (D)
THREADY_RETRY_FACTOR=2.0

# Back-off ceiling.
# Default: 5m. Scope: workers. (D)
THREADY_RETRY_CAP=5m

# Per-post soft budget (research-heavy).
# Default: 30m. Scope: workers. (D)
THREADY_POST_TIMEOUT=30m

# Per-Skill concurrency cap.
# Default: 8. Scope: workers. (D)
THREADY_SKILL_CONCURRENCY=8


# =============================================================================
# 13. AUTHENTICATION & SECURITY                           (configuration.md §11)
#     digital.vasic.auth defaults JWT to HMAC-SHA256; RS256/EdDSA + JWKS is P1 [GAP: 10].
# =============================================================================

# JWT algorithm: HS256|RS256|EdDSA.
# Default: HS256 (dev) -> RS256 (prod target). Scope: auth/all. (V) [GAP: 10]
THREADY_JWT_SIGNING_ALG=HS256

# HS256 secret (SECRET; >=32 bytes). HS256 only.
# Default: unset. Scope: auth/all. (V)
THREADY_JWT_SECRET=

# RS256/EdDSA PEM key paths.
# Default: unset. Scope: auth/all. (V)
# THREADY_JWT_PRIVATE_KEY_PATH=/secure/jwt.pem
# THREADY_JWT_PUBLIC_KEY_PATH=/secure/jwt.pub.pem

# Access token lifetime (Q9).
# Default: 15m. Scope: auth. (D)
THREADY_ACCESS_TOKEN_TTL=15m

# Refresh token lifetime.
# Default: 168h (7d). Scope: auth. (D)
THREADY_REFRESH_TOKEN_TTL=168h

# Web idle logout.
# Default: 30m. Scope: API/web. (D)
THREADY_IDLE_TIMEOUT=30m

# Tiers forced to MFA (CSV). TOTP mandatory for admin tiers, optional for users (Q9).
# Default: root,account_admin. Scope: auth. (D)
THREADY_MFA_REQUIRED_TIERS=root,account_admin

# Minimum password length (Argon2id-hashed; breach-list checked).
# Default: 12. Scope: auth. (D)
THREADY_PASSWORD_MIN_LEN=12

# Argon2id KDF memory (KiB).
# Default: 65536. Scope: auth. (V) [IN-HOUSE: security]
THREADY_ARGON2_MEMORY_KIB=65536

# Server-side pepper for API-key hashing (SECRET).
# Default: unset. Scope: auth. (V)
THREADY_API_KEY_HASH_PEPPER=

# AES-256-GCM master key for sealed storage (SECRET, 32 bytes; redacted).
# Default: unset. Scope: security/all. (V)
THREADY_ENCRYPTION_KEY=


# =============================================================================
# 14. DOWNLOADS & 3rd-PARTY SYSTEMS                       (configuration.md §12)
# =============================================================================

# Boba torrent search/download (SSE + POST /api/v1/hooks).
# Default: unset. Scope: workers. (V) [IN-HOUSE: Boba]
# THREADY_BOBA_URL=http://boba:8000

# Where Boba posts completion; contract being standardized.
# Default: derived. Scope: workers. (gap) [GAP: 6.4]
# THREADY_BOBA_CALLBACK_URL=https://thready.hxd3v.com/v1/hooks/boba

# MeTube video/streaming download.
# Default: unset. Scope: workers. (V) [IN-HOUSE: MeTube]
# THREADY_METUBE_URL=http://metube:8081

# MeTube outbound webhook — MeTube is POLL-ONLY today; webhook being added.
# Default: derived. Scope: workers. (BN) [BUILD-NEW] [GAP: 5]
# THREADY_METUBE_WEBHOOK_URL=https://thready.hxd3v.com/v1/hooks/metube

# Generic multi-protocol Download Manager — DOES NOT EXIST YET (being built).
# Default: unset. Scope: workers. (BN) [BUILD-NEW] [GAP: 4]
# THREADY_DOWNLOAD_MANAGER_URL=http://dlm:8082

# Parallel download jobs.
# Default: 4. Scope: workers. (D)
THREADY_DOWNLOAD_CONCURRENCY=4

# #Game default target platforms (CSV) (§3.2.2).
# Default: PC-Windows,PS4,Android. Scope: workers. (D)
THREADY_GAME_DEFAULT_PLATFORMS=PC-Windows,PS4,Android

# #Software default OSes (CSV).
# Default: Windows,Linux,macOS. Scope: workers. (D)
THREADY_SOFTWARE_DEFAULT_OS=Windows,Linux,macOS


# =============================================================================
# 15. ASSETS & MEDIA DIRECTORIES                          (configuration.md §13)
#     Client links resolve THROUGH the Asset Service, never via direct paths.
# =============================================================================

# Asset Service URL. Decoupling from Catalogizer + HLS/DASH transcode is P1 [GAP: 9].
# Default: unset. Scope: clients/workers. (BN) [BUILD-NEW]
# THREADY_ASSET_SERVICE_URL=http://assets:8090

# Root for downloaded media.
# Default: ./data/media. Scope: asset service. (op) [OPERATOR-editable]
THREADY_MEDIA_DIR=./data/media

# Suffix before extension for web-optimized renditions (Q36).
# Default: -web. Scope: asset service. (D)
THREADY_WEB_RENDITION_SUFFIX=-web

# AES-256-GCM directory for cards/contracts/QR/screenshots.
# Default: ./data/secure. Scope: asset service. (V) [IN-HOUSE: security]
THREADY_ENCRYPTED_ASSET_DIR=./data/secure

# Content-hash dedup + integrity checksums.
# Default: true. Scope: asset service. (gap) [GAP: 6.1]
THREADY_ASSET_DEDUP=true


# =============================================================================
# 16. OBSERVABILITY, LOGGING & BACKUP                     (configuration.md §14)
#     OpenTelemetry + Prometheus + logrus + ClickHouse (NOT ELK/Loki/Datadog).
# =============================================================================

# OTLP collector endpoint (Jaeger/Zipkin behind it).
# Default: unset. Scope: all services. (V) [IN-HOUSE: observability]
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel:4317

# Prometheus scrape endpoint.
# Default: 0.0.0.0:9090. Scope: all services. (V)
THREADY_METRICS_ADDR=0.0.0.0:9090

# ClickHouse log/analytics sink DSN.
# Default: unset. Scope: all services. (V)
# THREADY_CLICKHOUSE_DSN=clickhouse://ch:9000/thready

# Append-only audit-log retention (Q40).
# Default: 8760h (1y). Scope: audit. (D)
THREADY_AUDIT_RETENTION=8760h

# Daily full backup cron (Q41).
# Default: 0 3 * * *. Scope: backup. (op) [OPERATOR]
THREADY_BACKUP_FULL_CRON=0 3 * * *

# Hourly DB incrementals (RPO ~= 1h).
# Default: 0 * * * *. Scope: backup. (op) [OPERATOR]
THREADY_BACKUP_INCREMENTAL_CRON=0 * * * *

# Firebase Crashlytics/Analytics/Distribution (mobile) [CONSTITUTION §11.4.47].
# Default: unset. Scope: mobile. (V)
# FIREBASE_PROJECT_ID=thready-prod


# =============================================================================
# 17. RETENTION, BILLING & LOCALIZATION                   (configuration.md §15)
# =============================================================================

# Global default retention (duration | indefinite); Accounts may shorten (Q12).
# Default: indefinite. Scope: all services. (op) [OPERATOR]
THREADY_RETENTION_DEFAULT=indefinite

# Billing model. Metering on from day one (Q11).
# Default: subscription+metered. Scope: billing. (op) [OPERATOR]
THREADY_BILLING_MODE=subscription+metered

# Usage-event flush interval.
# Default: 1m. Scope: billing. (D)
THREADY_METERING_FLUSH=1m

# UI locale default: en|ru|sr-Cyrl (Q35).
# Default: en. Scope: web/mobile. (D)
THREADY_DEFAULT_LOCALE=en

# On-demand HelixTranslate service URL.
# Default: unset. Scope: web/workers. (V) [IN-HOUSE: HelixTranslate]
# THREADY_TRANSLATE_URL=http://translate:8095


# =============================================================================
# 18. WHITE-LABELING & BRANDING                           (configuration.md §16)
#     Env vars set only the SYSTEM DEFAULT for new Accounts; per-account overrides
#     live in the DB (edited by Root Admin), NOT here.
# =============================================================================

# System-default product name.
# Default: Thready. Scope: web/content. (op) [OPERATOR-editable]
THREADY_BRAND_NAME=Thready

# Brand base color (Helix-green); per-account override in DB.
# Default: #B6E376. Scope: web/content. (V) [IN-HOUSE: design_system]
THREADY_BRAND_PRIMARY_COLOR=#B6E376

# Default logo (theme derived from it).
# Default: ./assets/Logo.png. Scope: web/content. (op) [OPERATOR-editable]
THREADY_BRAND_LOGO_PATH=./assets/Logo.png

# Footer slogan (heart glyph); Helix attribution persists even under white-label.
# Default: Made with love ♥ by Helix Development. Scope: web/content. (op) [OPERATOR]
THREADY_BRAND_SLOGAN=Made with love ♥ by Helix Development

# Default theme: system|light|dark. Light + dark mandatory [CONSTITUTION §11.4.162].
# Default: system. Scope: web/mobile. (V)
THREADY_THEME_DEFAULT=system


